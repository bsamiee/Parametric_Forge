{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!flake.lock",
            "!pnpm-lock.yaml",
            "!node_modules/**",
            "!**/.archive/**",
            "!**/_archive/**",
            "!**/scratch/**",
            "!**/.scratch/**",
            "!**/_tmp/**",
            "!**/.tmp/**",
            "!**/.cache/**",
            "!**/.history/**",
            "!.claude/workflows/**",
            "!.claude/skills/workflow-creator/assets/**"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 150
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "json": {
        "parser": {
            "allowComments": true
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
