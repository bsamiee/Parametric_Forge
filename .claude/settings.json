{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "effortLevel": "high",
    "skillOverrides": {
        "ast-grep": "name-only",
        "heptabase-cli": "name-only",
        "ifc-bim": "name-only",
        "jupyter-notebooks": "name-only",
        "rhino-mcp": "name-only"
    },
    "claudeMdExcludes": [
        "**/.cache/**/CLAUDE.md",
        "**/node_modules/**/CLAUDE.md",
        "**/bin/**/CLAUDE.md",
        "**/obj/**/CLAUDE.md",
        "**/.artifacts/**/CLAUDE.md"
    ],
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-env.sh",
                        "timeout": 10
                    }
                ]
            }
        ]
    },
    "permissions": {
        "deny": [
            "Bash(git push --force:*)",
            "Bash(git push -f:*)",
            "Bash(git reset --hard:*)"
        ]
    }
}
