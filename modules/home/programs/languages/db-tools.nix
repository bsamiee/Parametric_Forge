# Database and SQL tooling: clients, linters, analytics, and the terminal
# front doors (Harlequin IDE, sq source catalog, VisiData tabular workbench).
{
  config,
  pkgs,
  lib,
  ...
}: let
  tomlFormat = pkgs.formats.toml {};

  # PostgreSQL 18 client roster; server extensions stay Docker-owned by forge-provision.
  postgres18ForgeTools = pkgs.runCommand "postgres18-forge-client-tools" {nativeBuildInputs = [pkgs.makeWrapper];} ''
    runHook preInstall
    mkdir -p "$out/bin"
    for bin in psql pg_dump pg_dumpall pg_restore pg_isready pgbench pg_amcheck createdb dropdb createuser dropuser vacuumdb reindexdb clusterdb; do
      makeWrapper "${pkgs.postgresql_18}/bin/$bin" "$out/bin/$bin"
    done
    runHook postInstall
  '';

  # Harlequin themes are named Textual themes only; dracula matches the estate
  # palette variant. One profile per local engine, DuckDB is the front door.
  harlequinProfile = adapter: {
    inherit adapter;
    theme = "dracula";
    limit = 500;
  };
  harlequinConfig = {
    default_profile = "duckdb";
    profiles = lib.genAttrs ["duckdb" "sqlite" "postgres"] harlequinProfile;
  };
in {
  home.packages = with pkgs; [
    sqlite-interactive # Enhanced sqlite3 shell with line editing and metadata helpers
    sqlite-vec # Vector similarity extension for SQLite
    sqlite-utils # Python-based CLI for SQLite database management
    libspatialite # Spatial SQL extension for geospatial work
    sqlfluff # SQL linter and formatter supporting multiple dialects
    duckdb # In-memory analytics database with SQL interface
    postgres18ForgeTools # PostgreSQL 18 client commands; server extensions are Docker-owned by forge-provision
    pgroll # Online PostgreSQL schema migration CLI
    pgloader # Data loading/migration into PostgreSQL
    pgbadger # PostgreSQL log analyzer
    parquet-tools # Parquet file inspector
    minio-client # S3-compatible object storage CLI (mc)
    s5cmd # Fast S3/object-store batch CLI
    usql # Universal SQL CLI for cross-database interactive sessions
    pgcli # Interactive PostgreSQL shell with completion
    litecli # Interactive SQLite shell with completion
    sqruff # Fast SQL linter/formatter for DuckDB-style SQL workflows
    pgformatter # PostgreSQL SQL formatter
    pg_activity # PostgreSQL activity monitor
    pgmetrics # PostgreSQL metric collection CLI
    sqlean # Extension library bundle (regexp, uuid, stats, etc.)
    postgres-language-server # Postgres LSP; includes postgres-language-server and postgrestools
    sqlite-forge # Explicit SQLite shell with SQLean, sqlite-vec, and SpatiaLite loaded
    (harlequin.override {withBigQueryAdapter = false;}) # Terminal SQL IDE with duckdb/sqlite/postgres adapters; config below
    sq # Cross-source catalog/query bridge; sq.yml is a self-mutating source catalog (user state), credentials stay in keyring/env
    visidata # Interactive tabular workbench for CSV/parquet/JSON/directory sheets; config below
  ];

  # HARLEQUIN_CONFIG_PATH (environments/languages.nix) pins discovery to this
  # file; the postgres profile rides libpq PG* environment defaults.
  xdg.configFile."harlequin/config.toml".source = tomlFormat.generate "harlequin-config" harlequinConfig;

  # VisiData colors are curses-palette only; the default dark theme stands.
  xdg.configFile."visidata/config.py".text = ''
    # Generated by Home Manager (Parametric Forge).
    options.visidata_dir = "${config.xdg.stateHome}/visidata"  # cmdlog/macros out of $HOME
    options.motd_url = ""  # no startup network fetch
  '';

  home.file.".sqliterc".text = lib.concatStringsSep "\n" [
    "-- Auto-generated by Home Manager (Parametric Forge)"
    "-- Harmless interactive defaults only; use sqlite-forge for native extensions."
    ""
    ".mode column"
    ".headers on"
    ".nullvalue NULL"
  ];
}
